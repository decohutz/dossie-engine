# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# Data (inputs and outputs are local, not committed)
data/inputs/*
data/outputs/*
data/versions/*
!data/inputs/.gitkeep
!data/outputs/.gitkeep
!data/versions/.gitkeep

# Environment
.env
.env.local

# IDE
.vscode/settings.json
.idea/

# OS
.DS_Store
Thumbs.db

# ──────────────────────────────────────────────────────────────
# Confidential test fixtures — NEVER commit
# Baselines contain real CIM data under NDA (financials, company
# names, projections). Lives locally only; tests skip gracefully
# when the fixture directory is absent.
# ──────────────────────────────────────────────────────────────
tests/fixtures/**
!tests/fixtures/README.md
!tests/fixtures/.gitkeep

# Pytest cache
.pytest_cache/